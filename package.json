{
  "name": "build-a-bear-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@drift-labs/sdk": "^2.156.0",
    "@solana/web3.js": "^1.95.8",
    "@voltr/vault-sdk": "^1.0.20",
    "axios": "^1.7.9",
    "bn.js": "^5.2.1",
    "dotenv": "^16.4.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsconfig-paths": "^4.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:ts": "npm run build --workspace @build-a-bear/core --workspace @build-a-bear/bot",
    "test": "npm run test --workspaces --if-present",
    "test:ts": "npm run test --workspace @build-a-bear/core --workspace @build-a-bear/bot",
    "test:all": "npm run test:ts && npm run ml:test",
    "ml:test": "python -m unittest discover -s ml/tests -p \"test_*.py\"",
    "ml:train": "python -m ml_pipeline.training.train_all",
    "ml:production": "python scripts/run_hackathon_pipeline.py",
    "bot:devnet:paper": "npm run devnet:paper --workspace @build-a-bear/bot",
    "api:dev": "npm run dev --workspace @build-a-bear/api",
    "web:dev": "npm run dev --workspace @build-a-bear/web",
    "web:build": "npm run build --workspace @build-a-bear/web",
    "app:build": "npm run build --workspace @build-a-bear/api && npm run build --workspace @build-a-bear/web",
    "app:start": "npm run dev --workspace @build-a-bear/api"
  }
}
